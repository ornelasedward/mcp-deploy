# Staging — mirrors production host layout under staging.* 
NODE_ENV=production
DEPLOY_ENV=staging

DATABASE_URL=postgresql://USER:PASS@HOST/agentd_staging?sslmode=require
TRACE_STORE=postgres

PLATFORM_DOMAIN=agentd.dev
PLATFORM_BASE_URL=https://api.staging.agentd.dev
WEB_BASE_URL=https://app.staging.agentd.dev

API_KEY=staging-bootstrap-key
GATEWAY=local
RUNTIME=local
DURABLE=inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

DEFAULT_ORG_ID=org_staging
ARTIFACTS_DIR=.artifacts
