# Production — use with Fly.io, Railway, or docker compose
NODE_ENV=production
DEPLOY_ENV=production

# Managed Postgres (Neon / Supabase / RDS)
DATABASE_URL=postgresql://USER:PASS@HOST/agentd?sslmode=require
TRACE_STORE=postgres

# Hosted URLs (required for P6)
PLATFORM_DOMAIN=agentd.dev
PLATFORM_BASE_URL=https://api.agentd.dev
WEB_BASE_URL=https://app.agentd.dev

API_KEY=change-me-in-production
AUTH_MODE=mixed
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

GATEWAY=live
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
RUNTIME=e2b
E2B_API_KEY=
E2B_TEMPLATE_ID=agentd-agent
BRIDGE_SECRET=change-me-bridge-secret
DEFAULT_EGRESS_ALLOWLIST=api.anthropic.com,api.openai.com
DURABLE=inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

DEFAULT_ORG_ID=org_prod
AGENTS_DIR=./examples
ARTIFACTS_DIR=.artifacts
GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN=

PUBLIC_RATE_LIMIT_PER_HOUR=30
PUBLIC_PER_RUN_USD_CAP=0.05
