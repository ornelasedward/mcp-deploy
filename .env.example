# --- Adapter selection (local|vendor). Defaults to local: runs with NO vendor accounts. ---
RUNTIME=local            # local | e2b
DURABLE=local            # local | inngest
GATEWAY=local            # local | live  (live uses a real provider via Vercel AI SDK)
TRACE_STORE=memory       # memory | postgres
TRACE_EXPORT=none        # none | langfuse | otel
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
OTEL_EXPORTER_OTLP_ENDPOINT=
EVAL_REGRESSION_DELTA=0.05
EVAL_BLOCK_DEPLOY=true

# --- Only needed when you flip an adapter to its vendor mode ---
DATABASE_URL=
E2B_API_KEY=
E2B_TEMPLATE_ID=
E2B_MOCK=
BRIDGE_SECRET=dev-bridge
DEFAULT_EGRESS_ALLOWLIST=api.anthropic.com,api.openai.com
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Platform ---
PLATFORM_BASE_URL=http://localhost:8787
WEB_BASE_URL=http://localhost:3000
PORT=8787
API_KEY=dev
AUTH_MODE=mixed
# Clerk (optional — enables sign-in + JWT auth)
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_DEV_ORG_ID=org_dev
NEXT_PUBLIC_API_BASE=http://localhost:8787
DEFAULT_ORG_ID=org_dev
AGENTS_DIR=./examples
ARTIFACTS_DIR=.artifacts
GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN=

# --- Default safety caps (cost runaway protection) ---
DEFAULT_PER_RUN_USD_CAP=0.50
DEFAULT_ORG_MONTHLY_USD_CAP=50
# 32+ char secret for AES-GCM encryption of project_secrets (required when DATABASE_URL set)
SECRETS_ENCRYPTION_KEY=
PUBLIC_RATE_LIMIT_PER_HOUR=30
PUBLIC_PER_RUN_USD_CAP=0.05

# --- Stripe billing (P13) — Billing Meters for LLM pass-through ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PLATFORM_MONTHLY=
STRIPE_PRICE_LLM_METERED=
STRIPE_METER_LLM_EVENT=agentd_llm_usage
BILLING_ENABLED=

# --- Enterprise BYOC (P14) — SAML + audit export ---
SAML_ENABLED=
SAML_SP_ENTITY_ID=http://localhost:8787
SAML_SP_ACS_URL=http://localhost:8787/v1/auth/saml/acs
SAML_IDP_SSO_URL=
SAML_IDP_CERT=
SAML_SESSION_SECRET=
SAML_ORG_ATTRIBUTE=orgId
