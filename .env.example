# --- Adapter selection (local|vendor). Defaults to local: runs with NO vendor accounts. ---
RUNTIME=local            # local | e2b
DURABLE=local            # local | inngest
GATEWAY=local            # local | live  (live uses a real provider via Vercel AI SDK)
TRACE_STORE=memory       # memory | postgres

# --- Only needed when you flip an adapter to its vendor mode ---
DATABASE_URL=
E2B_API_KEY=
E2B_TEMPLATE_ID=
E2B_MOCK=
BRIDGE_SECRET=dev-bridge
DEFAULT_EGRESS_ALLOWLIST=api.anthropic.com,api.openai.com
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Platform ---
PLATFORM_BASE_URL=http://localhost:8787
WEB_BASE_URL=http://localhost:3000
PORT=8787
API_KEY=dev
AUTH_MODE=mixed
# Clerk (optional — enables sign-in + JWT auth)
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_DEV_ORG_ID=org_dev
NEXT_PUBLIC_API_BASE=http://localhost:8787
DEFAULT_ORG_ID=org_dev
AGENTS_DIR=./examples
ARTIFACTS_DIR=.artifacts
GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN=

# --- Default safety caps (cost runaway protection) ---
DEFAULT_PER_RUN_USD_CAP=0.50
DEFAULT_ORG_MONTHLY_USD_CAP=50
# 32+ char secret for AES-GCM encryption of project_secrets (required when DATABASE_URL set)
SECRETS_ENCRYPTION_KEY=
PUBLIC_RATE_LIMIT_PER_HOUR=30
PUBLIC_PER_RUN_USD_CAP=0.05
